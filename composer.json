{
    "name": "blackpig-creatif/grimoire",
    "description": "In-panel documentation for FilamentPHP applications",
    "keywords": [
        "blackpig-creatif",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "documentation",
        "grimoire"
    ],
    "homepage": "https://github.com/blackpig/grimoire",
    "support": {
        "issues": "https://github.com/blackpig/grimoire/issues",
        "source": "https://github.com/blackpig/grimoire"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Blackpig Creatif",
            "email": "stuart@blackpig.eu",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "filament/filament": "^5.0",
        "league/commonmark": "^2.4",
        "spatie/laravel-package-tools": "^1.15.0",
        "spatie/yaml-front-matter": "^2.0",
        "tempest/highlight": "^2.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "BlackpigCreatif\\Grimoire\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BlackpigCreatif\\Grimoire\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "BlackpigCreatif\\Grimoire\\GrimoireServiceProvider"
            ],
            "aliases": {
                "Grimoire": "BlackpigCreatif\\Grimoire\\Facades\\Grimoire"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
